# Server
PORT=8080

# Database
DATABASE_URL=postgres://user:password@localhost:5432/thegame

# Admin (required for POST /api/admin/datasets/sync)
ADMIN_API_KEY=

# Google Maps Directions API (for route computation)
GOOGLE_ROUTES_API_KEY=
GOOGLE_MAPS_API_KEY=

# OpenAI (for AI story generation)
OPENAI_API_KEY=

# Locked constraints (do not change without MCD update)
KM_MIN=1
KM_MAX=15
MIN_GEMS=6
MAX_GEMS=10
DEFAULT_GEMS=8
ROUTE_TOLERANCE_PERCENT=10
ROUTE_MAX_RETRIES=2
